{
  "name": "racconto-desktop",
  "version": "0.1.0",
  "description": "Racconto Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "package:mac": "cd ../frontend && ELECTRON_BUILD=1 npm run build && cd ../electron && electron-builder --mac",
    "package:win": "cd ../frontend && ELECTRON_BUILD=1 npm run build && cd ../electron && electron-builder --win"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "exifr": "^7.1.3"
  },
  "build": {
    "appId": "app.racconto.desktop",
    "productName": "Racconto",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "queue.js",
      "folderMap.js",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "mac": {
      "category": "public.app-category.photography",
      "icon": "icons/icon.icns",
      "artifactName": "Racconto-beta-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "win": {
      "icon": "icons/icon.ico",
      "artifactName": "Racconto-beta-Setup.${ext}",
      "target": "nsis"
    },
    "afterSign": "scripts/notarize.js" 
  }
}
