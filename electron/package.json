{
  "name": "racconto-desktop",
  "version": "0.1.0",
  "description": "Racconto Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "exifr": "^7.1.3",
    "form-data": "^4.0.5",
    "node-fetch": "^3.3.2"
  },
  "build": {
    "appId": "app.racconto.desktop",
    "productName": "Racconto",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.photography"
    },
    "win": {
      "target": "nsis"
    }
  }
}
